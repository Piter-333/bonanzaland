    function getCellAnchor(el) {
      const st = spriteState.get(el);
      if (!st) return { x: 0, y: 0 };
      const rxRad = (st.rotationX * Math.PI) / 180;
      const ryRad = (st.rotationY * Math.PI) / 180;
      const w = el.naturalWidth || 0;
      const h = el.naturalHeight || 0;
      const shiftX = Math.sin(ryRad) * 0.18 * w * st.scale;
      const shiftY = Math.sin(rxRad) * 0.18 * h * st.scale;
      return { x: st.x + shiftX, y: st.y + shiftY };
    }

    if (pathCells.length) {
