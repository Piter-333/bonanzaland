    function buildPathCells() {
      const cellsByOrder = allCells
        .map((el, idx) => {
          const st = spriteState.get(el);
          const id = (el.getAttribute("data-id") || "").toLowerCase();
          const idNum = Number((id.match(/^spr(\d+)$/) || [])[1] || Number.NaN);
          return { el, z: st.z, asset: st.asset, idx, idNum };
        })
        .sort((a, b) => {
          const aHasId = Number.isFinite(a.idNum);
          const bHasId = Number.isFinite(b.idNum);
          if (aHasId && bHasId && a.idNum !== b.idNum) return a.idNum - b.idNum;
          if (a.z !== b.z) return a.z - b.z;
          return a.idx - b.idx;
        });

      const startOrderIndex = cellsByOrder.findIndex((c) => c.asset === "srart.png");
      const finishOrderIndex = cellsByOrder.findIndex((c) => c.asset === "finish.png");
      const path =
        startOrderIndex >= 0 && finishOrderIndex >= 0 && finishOrderIndex >= startOrderIndex
          ? cellsByOrder.slice(startOrderIndex, finishOrderIndex + 1)
          : [];

      allCells.forEach((el) => delete el.dataset.pathIndex);
      path.forEach((c, i) => {
        c.el.dataset.pathIndex = String(i);
      });
      return path;
    }

