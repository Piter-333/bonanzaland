    deleteCellBtn.addEventListener("click", () => {
      if (!selectedCell) {
        setToolStatus("РќРµС‚ РІС‹Р±СЂР°РЅРЅРѕР№ РєР»РµС‚РєРё");
        return;
      }
      const idx = allCells.indexOf(selectedCell);
      if (idx < 0) return;

      const removed = selectedCell;
      removed.remove();
      allCells.splice(idx, 1);
      selectedCell = allCells[Math.max(0, idx - 1)] || null;

      pathCells = buildPathCells();
      assignBonusSlots();
      if (pathCells.length) {
        chipPathIndex = Math.max(0, Math.min(pathCells.length - 1, chipPathIndex));
        const anchor = getCellAnchor(pathCells[chipPathIndex].el);
        setChipCell(anchor.x, anchor.y);
      }

      refreshSelect();
      refreshNewCellAssets();
      syncInputsFromSelected();
      setToolStatus("РљР»РµС‚РєР° СѓРґР°Р»РµРЅР°");
    });

    addCellBtn.addEventListener("click", () => {
      const asset = (newCellAsset.value || "").trim();
      if (!asset) {
        setToolStatus("Р’С‹Р±РµСЂРё Р°СЃСЃРµС‚ РґР»СЏ РЅРѕРІРѕР№ РєР»РµС‚РєРё");
        return;
      }

      const ref = selectedCell ? spriteState.get(selectedCell) : null;
      const nextZ =
        allCells.length > 0
          ? Math.max(...allCells.map((el) => spriteState.get(el).z)) + 1
          : 0;

      const img = document.createElement("img");
      img.className = "placed-sprite";
      img.src = asset;
      img.alt = "";

      const state = {
        x: ref ? ref.x + 24 : 640,
        y: ref ? ref.y + 24 : 360,
        z: nextZ,
        rotationX: ref ? ref.rotationX : 0,
        rotationY: ref ? ref.rotationY : 0,
        rotationZ: ref ? ref.rotationZ : 0,
        scale: ref ? ref.scale : 0.05,
        asset: asset.toLowerCase()
      };
      spriteState.set(img, state);

      const container = document.querySelector(".container");
      const chipEl = document.getElementById("chip-view");
      container.insertBefore(img, chipEl);
      allCells.push(img);
      bindCellClick(img);

      if (img.complete) {
        applyStateToCell(img);
      } else {
        img.addEventListener("load", () => applyStateToCell(img), { once: true });
      }

      selectedCell = img;
      refreshSelect();
      refreshNewCellAssets();
      syncInputsFromSelected();
      setToolStatus(`Р”РѕР±Р°РІР»РµРЅР° РєР»РµС‚РєР°: ${asset}`);
    });

    // Match sprite rendering with editor.html (pseudo-3D for X/Y and Z-spin on 2D plane).
    function parseNumber(str, fallback = 0) {
      const n = Number(str);
      return Number.isFinite(n) ? n : fallback;
    }

    function normalizeSpriteRender(img) {
      const st = spriteState.get(img) || {
        rotationX: 0,
        rotationY: 0,
        rotationZ: 0,
        scale: 1
      };

      const rx = st.rotationX;
      const ry = st.rotationY;
      const rz = st.rotationZ;
      const baseScale = st.scale;

      const rxRad = (rx * Math.PI) / 180;
      const ryRad = (ry * Math.PI) / 180;
      const sx = Math.max(0.1, Math.cos(ryRad)) * baseScale;
      const sy = Math.max(0.1, Math.cos(rxRad)) * baseScale;
      const shiftX = Math.sin(ryRad) * 0.18 * img.naturalWidth * baseScale;
      const shiftY = Math.sin(rxRad) * 0.18 * img.naturalHeight * baseScale;

      img.style.transform =
        `translate(-50%, -50%) translate(${shiftX}px, ${shiftY}px) rotate(${rz}deg) scale(${sx}, ${sy})`;
    }

    function initSpritesRender() {
      document.querySelectorAll(".placed-sprite").forEach((img) => {
        if (img.complete) {
          normalizeSpriteRender(img);
        } else {
          img.addEventListener("load", () => normalizeSpriteRender(img), { once: true });
        }
      });
    }

    refreshSelect();
    refreshNewCellAssets();
    syncInputsFromSelected();
    refreshDragModeClass();
    setToolStatus("РџР°РЅРµР»СЊ РіРѕС‚РѕРІР°. РњРѕР¶РЅРѕ СЃРєСЂС‹С‚СЊ Рё РІРµСЂРЅСѓС‚СЊ РєРЅРѕРїРєРѕР№ В«РџР°РЅРµР»СЊВ».");
    initSpritesRender();
  </script>
</body>

