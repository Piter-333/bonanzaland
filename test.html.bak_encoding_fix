            const sourceMaterial = Array.isArray(child.material) ? child.material[0] : child.material;
            const sourceMap = sourceMaterial && sourceMaterial.map ? sourceMaterial.map : null;
            child.material = new THREE.MeshPhongMaterial({
              color: 0xffffff,
              map: sourceMap || null,
              side: THREE.DoubleSide
            });
          }
        });

        const box = new THREE.Box3().setFromObject(model);
        const center = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        const maxDim = Math.max(size.x, size.y, size.z) || 1;
        const targetSize = 90;
        const fitScale = targetSize / maxDim;

        model.position.sub(center);
        model.scale.setScalar(fitScale);
        // Front view: cube face looks toward the camera.
        model.quaternion.copy(getFaceQuaternion("posZ"));
        scene.add(model);
        objectModel = model;
        const rawValue = frontAxisToValue[getFrontFaceKey(model)];
        rollResult.textContent = `Р’С‹РїР°Р»Рѕ: ${calibratedValueMap[rawValue]}`;
      },
