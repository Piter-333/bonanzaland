    function getFrontFaceKey(model) {
      const viewDir = new THREE.Vector3(0, 0, 1);
      const candidates = [
        { key: "posX", dir: new THREE.Vector3(1, 0, 0) },
        { key: "negX", dir: new THREE.Vector3(-1, 0, 0) },
        { key: "posY", dir: new THREE.Vector3(0, 1, 0) },
        { key: "negY", dir: new THREE.Vector3(0, -1, 0) },
        { key: "posZ", dir: new THREE.Vector3(0, 0, 1) },
        { key: "negZ", dir: new THREE.Vector3(0, 0, -1) }
      ];

      let bestKey = "posZ";
      let bestDot = -Infinity;

      for (const c of candidates) {
        const worldDir = c.dir.clone().applyQuaternion(model.quaternion);
        const dot = worldDir.dot(viewDir);
        if (dot > bestDot) {
          bestDot = dot;
          bestKey = c.key;
        }
      }

      return bestKey;
    }
