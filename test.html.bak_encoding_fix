    async function moveChipToPathIndex(targetIndex) {
      if (!pathCells.length) return;
      const clamped = Math.max(0, Math.min(pathCells.length - 1, targetIndex));
      if (chipMoving) {
        chipMoveQueuedIndex = clamped;
        return;
      }

      chipMoving = true;
      const direction = clamped >= chipPathIndex ? 1 : -1;

      // Always move one cell at a time to pass every cell on the path.
      while (chipPathIndex !== clamped) {
        chipPathIndex += direction;
        const next = pathCells[chipPathIndex];
        const a = getCellAnchor(next.el);
        setChipCell(a.x, a.y);
        await waitChipTransition();
        await waitMs(CHIP_STEP_PAUSE_MS);
      }

      handleCellLanding(pathCells[chipPathIndex].el);

      chipMoving = false;
      if (chipMoveQueuedIndex !== null && chipMoveQueuedIndex !== chipPathIndex) {
        const queued = chipMoveQueuedIndex;
        chipMoveQueuedIndex = null;
        moveChipToPathIndex(queued);
      } else {
        chipMoveQueuedIndex = null;
      }
    }

    function moveChipBySteps(steps) {
      const amount = Number(steps) || 0;
      if (!pathCells.length || amount <= 0) return;
      const target = Math.min(pathCells.length - 1, chipPathIndex + amount);
      moveChipToPathIndex(target);
    }

