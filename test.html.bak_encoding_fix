        objectModel.rotation.y += angularVelocity.y;
        objectModel.rotation.z += angularVelocity.z;
        angularVelocity.multiplyScalar(0.985);
        rollFramesLeft -= 1;

        if (rollFramesLeft <= 0 || angularVelocity.length() < 0.01) {
          isRolling = false;
          settleFromQuat = objectModel.quaternion.clone();
          settleToQuat = getFaceQuaternion(pendingFrontKey);
          isSettling = true;
          settleT = 0;
        }
      }

