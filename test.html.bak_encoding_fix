        objectModel.quaternion.slerpQuaternions(settleFromQuat, settleToQuat, settleT);
        if (settleT >= 1) {
          isSettling = false;
          const rawValue = frontAxisToValue[getFrontFaceKey(objectModel)];
          const rolledValue = calibratedValueMap[rawValue];
          rollResult.textContent = `Р’С‹РїР°Р»Рѕ: ${rolledValue}`;
