<!doctype html>
<html lang="ru">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>One Page</title>
  <style>
    html,
    body {
      height: 100%;
      margin: 0;
    }

    body {
      display: flex;
      justify-content: center;
      align-items: center;
      background: #020617;
      background-image:
        radial-gradient(circle at 15% 15%, rgba(212, 175, 55, 0.15) 0%, transparent 40%),
        radial-gradient(circle at 85% 85%, rgba(29, 63, 122, 0.25) 0%, transparent 50%),
        linear-gradient(135deg, #020617 0%, #040d21 50%, #000000 100%);
    }

    .tool-panel {
      position: fixed;
      left: 18px;
      top: 50%;
      transform: translateY(-50%);
      width: 240px;
      max-height: 88vh;
      overflow: auto;
      padding: 10px;
      border-radius: 10px;
      background: rgba(7, 18, 43, 0.92);
      border: 1px solid rgba(212, 175, 55, 0.55);
      color: #f2d78a;
      font: 13px/1.25 Arial, sans-serif;
      z-index: 1200;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
      transition: transform 220ms ease, opacity 220ms ease;
    }

    .tool-panel.hidden {
      transform: translate(-115%, -50%);
      opacity: 0;
      pointer-events: none;
    }

    .tool-show {
      position: fixed;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 1201;
      display: none;
      padding: 8px 10px;
      border-radius: 8px;
      border: 1px solid rgba(212, 175, 55, 0.7);
      background: rgba(7, 18, 43, 0.95);
      color: #f2d78a;
      cursor: pointer;
    }

    .tool-show.visible {
      display: block;
    }

    .tool-panel .title {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .tool-panel .row {
      display: flex;
      gap: 6px;
      align-items: center;
      margin-bottom: 6px;
      flex-wrap: wrap;
    }

    .tool-panel select,
    .tool-panel input,
    .tool-panel button {
      font: 12px Arial, sans-serif;
    }

    .tool-panel input {
      width: 68px;
    }

    .tool-panel .move-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 4px;
      width: 120px;
    }

    .placed-sprite.editable-drag {
      cursor: grab;
    }

    .placed-sprite.dragging {
      cursor: grabbing;
    }

    .tool-panel,
    .tool-show {
      display: none !important;
    }


    .container {
      position: relative;
      width: 1272px;
      height: 716px;
      transform: translateX(160px);
      overflow: hidden;
      border-radius: 24px;
      background-color: #050a14;
      border: 4px solid #b8860b;
      box-shadow:
        0 0 0 8px #020617,
        0 0 0 12px #d4af37,
        0 40px 100px rgba(0, 0, 0, 0.95);
    }

    .bg-video {
      display: none;
    }

    .bg-webgl {
      position: absolute;
      left: -120px;
      top: 0;
      width: calc(100% + 240px);
      height: 100%;
      z-index: 0;
      pointer-events: none;
    }

    .bg-webgl canvas {
      display: block;
      width: 100% !important;
      height: 100% !important;
    }

    .dice-view {
      position: absolute;
      left: 604px;
      top: 300px;
      z-index: 300;
      width: 150px;
      height: 150px;
      transform: translate(-50%, -62%);
    }

    .chip-view {
      position: absolute;
      left: 1041px;
      top: 620px;
      z-index: 200;
      width: 102px;
      height: 102px;
      transform: translate(-50%, -104%);
      transition: left 520ms ease, top 520ms ease;
      pointer-events: none;
    }

    .placed-sprite {
      position: absolute;
      left: 0;
      top: 0;
      transform-origin: center center;
      pointer-events: auto;
      cursor: pointer;
      user-select: none;
      backface-visibility: hidden;
      image-rendering: auto;
      will-change: transform;
    }

    .controls {
      position: absolute;
      left: 604px;
      top: 400px;
      z-index: 350;
      transform: translateX(-50%);
      display: flex;
      gap: 8px;
      align-items: center;
      padding: 8px 12px;
      border-radius: 12px;
      border: 2px solid #ffdb70;
      background: linear-gradient(180deg, #fce5d8 0%, #ebb49c 100%);
      box-shadow:
        0 4px 0 #b37357,
        0 8px 16px rgba(0, 0, 0, 0.4),
        inset 0 2px 4px rgba(255, 255, 255, 0.6),
        inset 0 -1px 2px rgba(0, 0, 0, 0.15);
      backdrop-filter: blur(2px);
    }

    .controls::before {
      content: '';
      position: absolute;
      inset: -6px;
      pointer-events: none;
      background:
        radial-gradient(circle at 5px 5px, #ffdb70 2px, #d4931a 4px, transparent 5px),
        radial-gradient(circle at calc(100% - 5px) 5px, #ffdb70 2px, #d4931a 4px, transparent 5px),
        radial-gradient(circle at 5px calc(100% - 5px), #ffdb70 2px, #d4931a 4px, transparent 5px),
        radial-gradient(circle at calc(100% - 5px) calc(100% - 5px), #ffdb70 2px, #d4931a 4px, transparent 5px);
      filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.3));
    }

    #roll-btn {
      position: relative;
      border: none;
      border-radius: 8px;
      padding: 6px 16px;
      font: 900 13px "Arial Rounded MT Bold", "Comic Sans MS", Arial, sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #fff;
      background: linear-gradient(180deg, #7ad444 0%, #4a9e18 100%);
