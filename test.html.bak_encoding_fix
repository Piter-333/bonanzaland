    function parseSpriteStateFromStyle(el, idx) {
      const transform = el.style.transform || "";
      const rx = Number((transform.match(/rotateX\(([-\d.]+)deg\)/i) || [])[1] || 0);
      const ry = Number((transform.match(/rotateY\(([-\d.]+)deg\)/i) || [])[1] || 0);
      const rz = Number((transform.match(/rotateZ\(([-\d.]+)deg\)/i) || [])[1] || 0);
      const sc = Number((transform.match(/scale\(([-\d.]+)\)/i) || [])[1] || 1);
      return {
        x: Number(el.style.left.replace("px", "")) || 0,
        y: Number(el.style.top.replace("px", "")) || 0,
        z: Number(el.style.zIndex || idx),
        rotationX: Number.isFinite(rx) ? rx : 0,
        rotationY: Number.isFinite(ry) ? ry : 0,
        rotationZ: Number.isFinite(rz) ? rz : 0,
        scale: Number.isFinite(sc) ? sc : 1,
        asset: (el.getAttribute("src") || "").toLowerCase()
      };
    }

