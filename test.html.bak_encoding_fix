    .onew-wheel-wrap {
      position: relative;
      width: 330px;
      height: 330px;
      margin: 0 auto 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, #b8860b 0%, #ffd700 50%, #8b6508 100%);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8), inset 0 2px 5px rgba(255, 255, 255, 0.4);
      padding: 6px;
    }

    .onew-wheel-wrap::after {
      content: '1w';
      position: absolute;
      left: 50%;
      top: 50%;
      width: 60px;
      height: 60px;
      transform: translate(-50%, -50%);
      background: linear-gradient(180deg, #1c2331 0%, #0b0e14 100%);
